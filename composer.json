{
    "name": "filipebastos0/buscador-cursos-alura",
    "description": "Projeto que busca os cursos no site da Alura",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Filipebastos0\\BuscadorCursos\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Filipe",
            "email": "filiipe.bastos0@gmail.com"
        }
    ],
    "require": {
        "guzzlehttp/guzzle": "^7.10",
        "symfony/dom-crawler": "^8.0",
        "symfony/css-selector": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phan/phan": "^6.0"
    },
    "scripts": {
        "lint": "phpcs src",
        "lint-fix": "phpcbf src",
        "analyze": "phan --allow-polyfill-parser",
        "test": "phpunit tests",
        "check": [
            "@lint",
            "@analyze",
            "@test"
        ],
        "post-update-cmd": [
        "@test"
        ]
    }
}
